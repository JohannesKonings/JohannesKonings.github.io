{
  "name": "tanstack",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "sync": "pnpm tsx ./../../scripts/syncWebsites.ts tanstack",
    "sync-content": "cp -r src/content public/",
    "dev": "pnpm sync && vp dev",
    "build": "pnpm sync && pnpm tsx ../../scripts/generateTanstackSitemap.ts && pnpm tsx ../../scripts/generateTanstackRss.ts && pnpm tsx ../../scripts/generateTanstackRobots.ts && vp build",
    "build:with-typecheck": "pnpm sync && pnpm tsx ../../scripts/generateTanstackSitemap.ts && pnpm tsx ../../scripts/generateTanstackRss.ts && pnpm tsx ../../scripts/generateTanstackRobots.ts && tsgo --noEmit && vp build",
    "start": "pnpm sync && vp start",
    "test": "vp test",
    "test:all": "pnpm run test:ui && pnpm run test:smoke",
    "test:smoke": "playwright test",
    "test:ui": "vp test run",
    "test:ui:dev": "vp test --ui",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@orama/orama": "1.2.4",
    "@tanstack/react-router": "1.124.0",
    "@tanstack/react-start": "1.124.0",
    "lucide-react": "0.577.0",
    "markdown-to-jsx": "9.7.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-syntax-highlighter": "15.6.1"
  },
  "devDependencies": {
    "@content-collections/core": "0.14.2",
    "@content-collections/vite": "0.2.9",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-router-devtools": "^1.161.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "10.4.27",
    "date-fns": "4.1.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "postcss": "8.5.8",
    "reading-time": "1.5.0",
    "tailwindcss": "4.2.1",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "catalog:",
    "zod": "4.3.6"
  }
}
