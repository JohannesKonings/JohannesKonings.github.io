{
  "name": "johanneskonings.github.io",
  "version": "1.0.0",
  "description": "Personal website and blog",
  "homepage": "johanneskonings.dev",
  "bugs": {
    "url": "https://github.com/JohannesKonings/JohannesKonings.github.io/issues"
  },
  "license": "MIT",
  "author": "Johannes Konings",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JohannesKonings/JohannesKonings.github.io.git"
  },
  "type": "module",
  "scripts": {
    "sync": "vp exec tsx scripts/syncWebsites.ts",
    "dev": "vp run sync && vp dev",
    "build": "vp run sync && vp exec tsx scripts/generateTanstackSitemap.ts && vp exec tsx scripts/generateTanstackRss.ts && vp build",
    "build:with-typecheck": "vp run sync && vp exec tsgo --noEmit && vp build",
    "start": "vp run sync && vp start",
    "test:ui": "vp test run",
    "test:ui:dev": "vp test --ui",
    "test:smoke": "playwright test",
    "test:all": "vp run test:ui && vp run test:smoke",
    "type-check": "vp exec tsgo --noEmit",
    "verify": "vp exec tsx scripts/verifyTanstack.ts",
    "verify:seo-geo": "vp exec tsx scripts/verifyTanstackSeoGeo.ts",
    "verify:lighthouse": "vp exec tsx scripts/runTanstackLighthouse.ts",
    "knip": "vp exec knip",
    "format:check": "vp fmt --check",
    "format:fix": "vp fmt",
    "lint:check": "vp lint",
    "lint:fix": "vp lint --fix",
    "demo:theme": "node scripts/theme-toggle-demo.mjs",
    "tsc": "vp exec tsgo",
    "tsc:check": "vp exec tsgo --noEmit",
    "tsc:watch": "vp exec tsgo -w",
    "checks:hook": "vp check",
    "checks:pr": "vp check && vp run test:all && vp run build && vp run verify:seo-geo && vp run verify:lighthouse",
    "prepare": "vp config"
  },
  "dependencies": {
    "@orama/orama": "1.2.4",
    "@tanstack/react-router": "1.124.0",
    "@tanstack/react-start": "1.124.0",
    "lucide-react": "0.577.0",
    "markdown-to-jsx": "9.7.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-syntax-highlighter": "15.6.1"
  },
  "devDependencies": {
    "@content-collections/core": "0.14.2",
    "@content-collections/vite": "0.2.9",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-router-devtools": "1.161.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260312.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/ui": "4.0.18",
    "autoprefixer": "10.4.27",
    "date-fns": "4.1.0",
    "execa": "9.6.1",
    "jsdom": "28.1.0",
    "knip": "5.86.0",
    "playwright": "1.58.2",
    "postcss": "8.5.8",
    "reading-time": "1.5.0",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.8",
    "vite-plus": "0.1.8",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.8",
    "zod": "4.3.6"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "js-yaml@^3.13.1": "3.14.2",
      "minimatch@^10.1.1": "10.2.3",
      "minimatch@^5.1.0": "5.1.8",
      "minimatch@^9.0.4": "9.0.7",
      "rollup": "4.59.0",
      "tar@^7.4.0": "7.5.10"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
