{
  "name": "johanneskonings.github.io",
  "version": "1.0.0",
  "description": "Blogging and Accounts",
  "homepage": "johanneskonings.dev",
  "bugs": {
    "url": "https://github.com/JohannesKonings/JohannesKonings.github.io/issues"
  },
  "license": "MIT",
  "author": "Johannes Konings",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JohannesKonings/JohannesKonings.github.io.git"
  },
  "type": "module",
  "scripts": {
    "knip": "vp exec knip",
    "format:check": "vp fmt --check",
    "format:fix": "vp fmt",
    "lint:check": "vp lint",
    "lint:fix": "vp lint --fix",
    "dev:tanstack": "vp run --filter tanstack dev",
    "demo:theme": "node websites/tanstack/scripts/theme-toggle-demo.mjs",
    "build:tanstack": "vp run --filter tanstack build",
    "verify:tanstack": "vp exec tsx scripts/verifyTanstack.ts",
    "verify:tanstack:seo-geo": "vp exec tsx scripts/verifyTanstackSeoGeo.ts",
    "verify:tanstack:lighthouse": "vp exec tsx scripts/runTanstackLighthouse.ts",
    "tsc": "vp exec tsgo",
    "tsc:check": "vp exec tsgo --noEmit",
    "tsc:watch": "vp exec tsgo -w",
    "checks:hook": "vp check",
    "checks:pr": "vp check && vp run --filter tanstack test:all && vp run build:tanstack && vp run verify:tanstack:seo-geo && vp run verify:tanstack:lighthouse",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@types/node": "24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260219.1",
    "execa": "9.6.1",
    "knip": "5.86.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@^5.0.0": "5.0.1",
      "js-yaml@^3.13.1": "3.14.2",
      "minimatch@^10.1.1": "10.2.3",
      "minimatch@^5.1.0": "5.1.8",
      "minimatch@^9.0.4": "9.0.7",
      "rollup": "4.59.0",
      "tar@^7.4.0": "7.5.10"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
