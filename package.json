{
  "name": "johanneskonings.github.io",
  "version": "1.0.0",
  "description": "Blogging and Accounts",
  "homepage": "johanneskonings.dev",
  "bugs": {
    "url": "https://github.com/JohannesKonings/JohannesKonings.github.io/issues"
  },
  "license": "GPL-3.0-or-later",
  "author": "Johannes Konings",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JohannesKonings/JohannesKonings.github.io.git"
  },
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "knip": "knip",
    "format:check": "pnpm oxfmt --check \"**/*.{js,mjs,cjs,jsx,ts,tsx,json,css,html}\" \"!websites/tanstack/src/routeTree.gen.ts\"",
    "format:fix": "pnpm oxfmt --write \"**/*.{js,mjs,cjs,jsx,ts,tsx,json,css,html}\" \"!websites/tanstack/src/routeTree.gen.ts\"",
    "lint:check": "pnpm oxlint",
    "lint:fix": "pnpm oxlint --fix",
    "dev:tanstack": "pnpm --filter tanstack dev",
    "demo:theme": "node websites/tanstack/scripts/theme-toggle-demo.mjs",
    "build:tanstack": "pnpm --filter tanstack build",
    "verify:tanstack": "tsx scripts/verifyTanstack.ts",
    "tsc": "tsgo",
    "tsc:check": "tsgo --noEmit",
    "tsc:watch": "tsgo -w"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260219.1",
    "execa": "9.6.1",
    "knip": "5.86.0",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@^5.0.0": "5.0.1",
      "js-yaml@^3.13.1": "3.14.2",
      "minimatch@^10.1.1": "10.2.3",
      "minimatch@^5.1.0": "5.1.8",
      "minimatch@^9.0.4": "9.0.7",
      "rollup": "4.59.0",
      "tar@^7.4.0": "7.5.10"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
